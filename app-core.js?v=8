  panel.classList.toggle('wide');
}

function filterNotifs(type, el) {
  document.querySelectorAll('.notif-tab').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
  document.querySelectorAll('#notif-list .up-item').forEach(item => {
    const dt = item.dataset.type || '';
    if (type === 'all') { item.style.display = ''; }
    else if (type === 'unread') { item.style.display = dt.includes('unread') ? '' : 'none'; }
    else if (type === 'mentions') { item.style.display = dt.includes('mentions') ? '' : 'none'; }
  });
  // Show/hide date labels based on visible items
  document.querySelectorAll('#notif-list .notif-date-label').forEach(lbl => {
    let next = lbl.nextElementSibling;
    let hasVisible = false;
    while (next && !next.classList.contains('notif-date-label')) {
      if (next.style.display !== 'none' && next.classList.contains('up-item')) hasVisible = true;
      next = next.nextElementSibling;
    }
    lbl.style.display = hasVisible ? '' : 'none';
  });
}

// ===== AI PANEL =====
function toggleAI() {
  const panel = document.getElementById('ai-panel');
  const btn = document.getElementById('btn-ai');
  aiOpen = !aiOpen;
  panel.classList.toggle('open', aiOpen);
  if (btn) btn.classList.toggle('active', aiOpen);
  // Sync overlay AI button state
  const overlayAiBtn = document.querySelector('.mm-ai-btn');
  if (overlayAiBtn) overlayAiBtn.classList.toggle('active', aiOpen);
  // Scroll chat to bottom when opening
  if (aiOpen) {
    setTimeout(() => {
      const chat = document.getElementById('ap-chat');
      if (chat) chat.scrollTop = chat.scrollHeight;
    }, 50);
  }
}

function sendAiMsg() {
  const input = document.getElementById('ap-input');
  const chat = document.getElementById('ap-chat');
  if (!input || !chat || !input.value.trim()) return;
  const text = input.value.trim();
  input.value = '';
  // Add user message
  const userMsg = document.createElement('div');
  userMsg.className = 'ap-msg ap-msg-user';
  userMsg.innerHTML = '<div class="ap-bubble">' + text.replace(/</g,'&lt;') + '</div>';
  chat.appendChild(userMsg);
  chat.scrollTop = chat.scrollHeight;
  // Simulate AI thinking
  setTimeout(() => {
    const aiMsg = document.createElement('div');
    aiMsg.className = 'ap-msg ap-msg-ai';
    aiMsg.innerHTML = '<div class="ap-label">AI Assistant</div><div class="ap-bubble">I\'m analyzing your request. In a production environment, this would connect to the AI backend for real-time analysis of your RFQ data, cost models, and capacity planning.</div>';
    chat.appendChild(aiMsg);
    chat.scrollTop = chat.scrollHeight;
  }, 800);
}

// Enter key to send
document.addEventListener('keydown', function(e) {
  if (e.key === 'Enter' && document.activeElement && document.activeElement.id === 'ap-input') {
    e.preventDefault();
    sendAiMsg();
  }
});

