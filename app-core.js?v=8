// ===== SEARCH PILLS =====
var searchPillStore = { rfq: [], jobs: [], quality: [] };
var savingViewModule = 'rfq';

function handleSearchKeydown(e, module) {
  if (e.key === 'Enter') {
    e.preventDefault();
    var input = e.target;
    var term = input.value.trim();
    if (!term) return;
    var exists = searchPillStore[module].some(function(p) { return p.text.toLowerCase() === term.toLowerCase(); });
    if (exists) { input.value = ''; return; }
    searchPillStore[module].push({ text: term });
    input.value = '';
    if (module === 'rfq') applyRfqFilters();
    else if (module === 'jobs') applyJobsFilters();
    else if (module === 'quality') applyQualityFilters();
  }
}

function removeSearchPill(module, idx) {
  searchPillStore[module].splice(idx, 1);
  if (module === 'rfq') applyRfqFilters();
  else if (module === 'jobs') applyJobsFilters();
  else if (module === 'quality') applyQualityFilters();
}

function saveCurrentView(module) {
  savingViewModule = module;
  openSvModal();
}

function renderSearchPillsHtml(module) {
  var pills = searchPillStore[module];
  var html = '';
  pills.forEach(function(pill, i) {
    html += '<span class="search-pill">' +
      '<span class="mi sp-icon">search</span>' +
      pill.text +
      '<span class="mi sp-save" onclick="event.stopPropagation();saveCurrentView(\'' + module + '\')" title="Save as filter">bookmark_border</span>' +
      '<span class="mi sp-x" onclick="removeSearchPill(\'' + module + '\',' + i + ')">close</span>' +
      '</span>';
  });
  return html;
}

function matchesSearchPills(module, text) {
  var pills = searchPillStore[module];
  for (var i = 0; i < pills.length; i++) {
    if (!text.includes(pills[i].text.toLowerCase())) return false;
  }
  return true;
}

// ===== NAVIGATION =====
function navigateTo(page) {
  const config = pages[page];
  if (!config) return;
  currentPage = page;

  // Hide all pages, show target
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  const el = document.getElementById('page-' + page);
  if (el) el.classList.add('active');

  // Shell visibility (hide for login/tablet pages)
  const header = document.getElementById('top-header');
  const tray = document.getElementById('action-tray');

  if (config.hideShell) {
    header.style.display = 'none';
    tray.classList.remove('visible');
    document.getElementById('utility-panel').classList.remove('open');
    document.getElementById('ai-panel').classList.remove('open');
  } else {
    header.style.display = '';
  }

  // Update tab active state
  document.querySelectorAll('.th-tab[data-page]').forEach(tab => {
    tab.classList.toggle('active', tab.dataset.page === config.tab);
  });

  // Update action tray — prepend "Back to ___" if navigated from Reports or Pipeline
  var trayConfig = config.tray;
  if (window._navFromReports && trayConfig && trayConfig.left) {
    var backPrefix = '<span class="at-bc-link" onclick="window._navFromReports=false;navigateTo(\'reports\')" style="display:inline-flex;align-items:center;gap:4px"><span class="mi" style="font-size:14px">arrow_back</span>Back to Reports</span>' +
      '<span style="display:inline-block;width:1px;height:16px;background:var(--steel-600);margin:0 12px;vertical-align:middle;flex-shrink:0"></span>';
    var newLeft = trayConfig.left.replace('<div class="at-breadcrumb">', '<div class="at-breadcrumb">' + backPrefix);
    trayConfig = { left: newLeft, center: trayConfig.center, right: trayConfig.right };
  }
  if (window._navFromPipeline && trayConfig && trayConfig.left) {
    var backPrefix = '<span class="at-bc-link" onclick="window._navFromPipeline=false;navigateTo(\'rfq-board\')" style="display:inline-flex;align-items:center;gap:4px"><span class="mi" style="font-size:14px">arrow_back</span>Back to Pipeline</span>' +
      '<span style="display:inline-block;width:1px;height:16px;background:var(--steel-600);margin:0 12px;vertical-align:middle;flex-shrink:0"></span>';
    var newLeft = trayConfig.left.replace('<div class="at-breadcrumb">', '<div class="at-breadcrumb">' + backPrefix);
    trayConfig = { left: newLeft, center: trayConfig.center, right: trayConfig.right };
  }
  if (page === 'reports' || page === 'dashboard' || page === 'rfqs' || page === 'jobs' || page === 'quality') {
    window._navFromReports = false;
  }
  if (page === 'rfq-board' || page === 'dashboard' || page === 'rfqs' || page === 'jobs' || page === 'quality' || page === 'reports') {
    window._navFromPipeline = false;
  }
  updateActionTray(trayConfig);

  // Scroll active page to top
  if (el) el.scrollTop = 0;

  // Page-specific init: load default view or update count when entering RFQs page
  if (page === 'rfqs') {
    setTimeout(() => {
      if (defaultView && savedViews[defaultView]) {
        loadSavedView(defaultView);
      } else {
        applyRfqFilters();
      }
    }, 0);
  }
  if (page === 'jobs') {
    setTimeout(() => { updateJobsCount(); }, 0);
  }
  if (page === 'quality') {
    setTimeout(() => { updateQualityCount(); }, 0);
  }
}

function updateActionTray(trayConfig) {
  const tray = document.getElementById('action-tray');
  const left = document.getElementById('at-left');
  const center = document.getElementById('at-center');
  const right = document.getElementById('at-right');

  if (!trayConfig) {
    tray.classList.remove('visible');
    left.innerHTML = '';
    center.innerHTML = '';
    right.innerHTML = '';
    return;
  }

  tray.classList.add('visible');
  left.innerHTML = trayConfig.left || '';
  center.innerHTML = trayConfig.center || '';
  right.innerHTML = trayConfig.right || '';
}

