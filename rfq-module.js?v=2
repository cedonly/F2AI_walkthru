// ===== CLOSE ALL PANELS =====
function closeAllPanels() {
  const utility = document.getElementById('utility-panel');
  const ai = document.getElementById('ai-panel');
  const scrim = document.getElementById('scrim');
  utility.classList.remove('open');
  ai.classList.remove('open');
  if (scrim) scrim.classList.remove('visible');
  utilityOpen = false;
  aiOpen = false;
  document.getElementById('btn-ai')?.classList.remove('active');
  document.getElementById('btn-notif')?.classList.remove('active');
}

// ===== TAB NAV CLICK (header tabs) =====
document.querySelectorAll('.th-tab[data-page]').forEach(tab => {
  tab.addEventListener('click', () => navigateTo(tab.dataset.page));
});

// ===== TAB BAR CLICK (non-navigating tabs) =====
document.querySelectorAll('.tab-bar').forEach(bar => {
  bar.querySelectorAll('.tab').forEach(tab => {
    if (!tab.getAttribute('onclick')) {
      tab.addEventListener('click', () => {
        bar.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
        tab.classList.add('active');
      });
    }
  });
});

// ===== CHIP CLICK TOGGLE =====
document.querySelectorAll('.chips').forEach(chipGroup => {
  chipGroup.querySelectorAll('.chip').forEach(chip => {
    chip.addEventListener('click', () => {
      chipGroup.querySelectorAll('.chip').forEach(c => c.classList.remove('active'));
      chip.classList.add('active');
    });
  });
});

// ===== DASHBOARD: yard filter =====
(function(){
  const filters = document.getElementById('yard-filters');
  const carousel = document.getElementById('rfq-carousel');
  if (!filters || !carousel) return;
  filters.querySelectorAll('.chip').forEach(chip => {
    chip.addEventListener('click', () => {
      const yard = chip.dataset.yard;
      carousel.querySelectorAll('.rfq-card').forEach(card => {
        if (yard === 'all') { card.style.display = ''; }
        else if (yard === 'unclass') { card.style.display = card.dataset.sec === 'unclass' ? '' : 'none'; }
        else { card.style.display = card.dataset.yard === yard ? '' : 'none'; }
      });
    });
  });
})();

// ===== VIEW TOGGLE (list/card) — Dashboard =====
function switchView(view) {
  const carousel = document.getElementById('rfq-carousel');
  const listView = document.getElementById('rfq-list-view');
  const toggle = document.getElementById('view-toggle');
  const btns = toggle.querySelectorAll('.view-toggle-btn');
  btns.forEach(b => b.classList.toggle('active', b.dataset.view === view));
  if (view === 'list') {
    carousel.style.display = 'none';
    listView.style.display = 'block';
    sortListView();
  } else {
    carousel.style.display = 'flex';
    listView.style.display = 'none';
  }
}

// ===== VIEW TOGGLE (list/cards) — RFQ & Bids =====
function switchRfqView(view) {
  const listW = document.getElementById('rfq-list-wrapper');
  const cardsW = document.getElementById('rfq-cards-wrapper');
  // Update toggle buttons in action tray
  const toggle = document.getElementById('rfq-view-toggle');
  if (toggle) {
    toggle.querySelectorAll('.view-toggle-btn').forEach(b => b.classList.toggle('active', b.dataset.view === view));
  }
  if (view === 'cards') {
    if (listW) listW.style.display = 'none';
    if (cardsW) cardsW.style.display = 'block';
  } else {
    if (listW) listW.style.display = '';
    if (cardsW) cardsW.style.display = 'none';
  }
}

// ===== SORT CAROUSEL =====
let dashSortVal = 'fit';
function sortCarousel() {
  const carousel = document.getElementById('rfq-carousel');
  const sortBy = dashSortVal;
  const cards = [...carousel.querySelectorAll('.rfq-card')];
  cards.sort((a, b) => {
    if (sortBy === 'fit') return Number(b.dataset.fit) - Number(a.dataset.fit);
    if (sortBy === 'posted') return a.dataset.posted.localeCompare(b.dataset.posted);
    if (sortBy === 'size') return Number(b.dataset.size) - Number(a.dataset.size);
    return 0;
  });
  cards.forEach(card => carousel.appendChild(card));
  sortListView();
}

function sortListView() {
  const tbody = document.querySelector('#rfq-list-view tbody');
  if (!tbody) return;
  const sortBy = dashSortVal;
  const rows = [...tbody.querySelectorAll('tr')];
  rows.sort((a, b) => {
    if (sortBy === 'fit') return Number(b.dataset.fit) - Number(a.dataset.fit);
    if (sortBy === 'posted') return a.dataset.posted.localeCompare(b.dataset.posted);
    if (sortBy === 'size') return Number(b.dataset.size) - Number(a.dataset.size);
    return 0;
  });
  rows.forEach(r => tbody.appendChild(r));
}

// ===== RFQ TABLE DATA GENERATION =====
function buildRfqData() {
  const yards = ['HII-Ingalls','HII-Newport News','Bath Iron Works','Electric Boat','GD-NASSCO','Austal USA','Fincantieri Marinette'];
  const progs = [{c:'DDG-51',n:'DDG-51 FIII'},{c:'CVN-81',n:'CVN-81 Ford'},{c:'SSN-810',n:'SSN-810 Virginia'},{c:'SSBN-826',n:'SSBN-826 Columbia'},{c:'LPD-32',n:'LPD-32'},{c:'FFG-62',n:'FFG-62 Constellation'},{c:'LHA-9',n:'LHA-9'},{c:'T-AO-205',n:'T-AO-205'},{c:'EPF',n:'EPF Spearhead'}];
  const parts = ['Pump mounting bracket','Valve body','Shaft coupling','Motor mount','Deck plate insert','Hull stiffener','Bearing housing','Pipe spool assembly','Stanchion base','Structural bracket','Rudder bearing assembly','Anchor chain stopper','Ventilation duct','Bilge keel bracket','Reduction gear housing','Keel block pad','Pressure hull frame','Davit arm','Hatch frame','Propeller shaft section','Sea chest grating','Hull insert plate','Bulkhead stiffener','Foundation pad','Cable tray support','Tank top plating','Sonar dome panel','Mast support bracket','Exhaust duct section','Cooling water pipe','Stern tube bearing','Windlass mount','Capstan base plate','Chock fitting','Bollard plate','Scupper housing','Ladder bracket','Door frame assembly','Hatch coaming ring','Tank access cover','Ventilation plenum','Pump base plate','Condenser housing','Heat exchanger shell','Fire main tee','Watertight door frame','Thruster tunnel ring','Rudder post','Shaft strut','Bilge pump mount'];
  const mats = ['HY-80','HY-100','HY-130','HSLA-80','CRES 316L','CRES 304L','CuNi 70/30','AL 5456','AL 5083','DH-36'];
  const procs = ['weldment','forging','machined','cast','flame cut','welded','fabrication','CNC machined'];

  // Deterministic pseudo-random for consistent prototype data
  let seed = 54321;
  const r = () => { seed = (seed * 16807) % 2147483647; return (seed - 1) / 2147483646; };
  const pick = a => a[Math.floor(r() * a.length)];

  const data = [];
  const now = new Date('2026-02-14T12:00:00');

  for (let i = 0; i < 150; i++) {
    // Spread posts over ~8 months: recent rows more frequent
    const daysBack = i < 7 ? Math.floor(r() * 3) :
                     i < 25 ? 3 + Math.floor(r() * 28) :
                     i < 60 ? 31 + Math.floor(r() * 60) :
                     91 + Math.floor(r() * 150);

    const posted = new Date(now);
    posted.setDate(posted.getDate() - daysBack);
    const due = new Date(posted);
    due.setDate(due.getDate() + 14 + Math.floor(r() * 28));

    // Status distribution based on age
    let status;
    if (i < 7) status = pick(['New','New','New','In Estimating']);
    else if (daysBack < 14) status = pick(['New','In Estimating','In Estimating','Internal Review']);
    else if (daysBack < 45) status = pick(['In Estimating','Internal Review','Submitted','Submitted']);
    else if (daysBack < 100) status = pick(['Submitted','Submitted','Internal Review','Awarded','Lost']);
    else status = pick(['Awarded','Awarded','Awarded','Lost','Lost','Submitted']);

    const fit = (status === 'Awarded' || status === 'Lost') ? 0 : 42 + Math.floor(r() * 56);
    const value = 12 + Math.floor(r() * 488);
    const prog = pick(progs);

    data.push({
      id: 'RFQ-2026-' + String(300 - i).padStart(4, '0'),
      yard: pick(yards), program: prog.c, programName: prog.n,
      desc: pick(parts) + ', ' + pick(mats) + ' ' + pick(procs),
      posted: posted.toISOString().slice(0, 10),
      due: due.toISOString().slice(0, 10),
      fit, status, value
    });
  }

  // Inject RFQ-0147 for demo (pump bracket, HII-Ingalls, Submitted)
  data.push({
    id: 'RFQ-2026-0147', yard: 'HII-Ingalls', program: 'T-AO-205', programName: 'T-AO-205',
    desc: 'Pump bracket, HY-80 weldment', posted: '2026-02-13', due: '2026-03-06',
    fit: 94, status: 'Submitted', value: 48
  });

  // Sort newest first
  data.sort((a, b) => b.posted.localeCompare(a.posted));
  // Mark first 7 as new/unseen
  data.forEach((d, i) => d.isNew = i < 7);
  return data;
}

const rfqData = buildRfqData();

function renderRfqTable() {
  const tbody = document.getElementById('rfq-tbody');
  if (!tbody) return;
  const now = new Date('2026-02-14T12:00:00');
  const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];

  let html = '';
  rfqData.forEach(d => {
    // Posted display — relative for recent, date for older
    const posted = new Date(d.posted + 'T12:00:00');
    const diffMs = now - posted;
    const diffHrs = Math.floor(diffMs / 3600000);
    const diffDays = Math.floor(diffMs / 86400000);
    let postedStr;
    if (diffHrs < 1) postedStr = Math.max(1, Math.floor(diffMs / 60000)) + 'm';
    else if (diffHrs < 24) postedStr = diffHrs + 'hrs';
    else if (diffDays < 7) postedStr = diffDays + 'd ago';
    else postedStr = months[posted.getMonth()] + ' ' + posted.getDate();

    // Due display
    const dueD = new Date(d.due + 'T12:00:00');
    const dueStr = months[dueD.getMonth()] + ' ' + dueD.getDate();

    // Fit display with progress bar
    let fitHtml;
    if (d.fit === 0) {
      fitHtml = '\u2014';
    } else {
      const fitColor = d.fit >= 90 ? 'green' : d.fit >= 75 ? 'cyan' : d.fit >= 65 ? 'yellow' : 'orange';
      fitHtml = '<div style="display:flex;align-items:center;gap:6px"><div class="progress-bar" style="width:50px"><div class="progress-fill ' + fitColor + '" style="width:' + d.fit + '%"></div></div><span style="font-size:12px;font-weight:600">' + d.fit + '</span></div>';
    }

    // Status badge
    const statusMap = { 'New': 'badge-blue', 'In Estimating': 'badge-cyan', 'Internal Review': 'badge-yellow', 'Submitted': 'badge-green', 'Awarded': 'badge-emerald' };
    const statusCls = statusMap[d.status];
    const statusBadge = statusCls
      ? '<span class="badge ' + statusCls + '">' + d.status + '</span>'
      : '<span class="badge" style="background:rgba(107,114,128,.15);color:var(--steel-300)">' + d.status + '</span>';

    // New badge
    const newBadge = d.isNew ? '<span class="rfq-new-badge">NEW</span>' : '';

    var rowId = (d.id === 'RFQ-2026-0147') ? ' id="rfq-row-0147"' : '';
    html += '<tr onclick="navigateTo(\'rfq-detail\')"' + rowId
      + ' data-status="' + d.status + '" data-yard="' + d.yard + '" data-program="' + d.program + '"'
      + ' data-fit="' + d.fit + '" data-due="' + d.due + '" data-value="' + d.value + '"'
      + ' data-posted="' + d.posted + '"' + (d.isNew ? ' data-new="true"' : '') + '>'
      + '<td style="color:var(--cyan-400);font-weight:600;font-family:var(--font-mono)">' + d.id + newBadge + '</td>'
      + '<td style="color:var(--steel-300);font-size:12px">' + postedStr + '</td>'
      + '<td>' + d.yard + '</td>'
      + '<td>' + d.programName + '</td>'
      + '<td>' + d.desc + '</td>'
      + '<td>' + dueStr + '</td>'
      + '<td>' + fitHtml + '</td>'
      + '<td>' + statusBadge + '</td>'
      + '<td style="text-align:right;font-weight:600">$' + d.value + 'K</td>'
      + '</tr>';
  });
  tbody.innerHTML = html;
}

