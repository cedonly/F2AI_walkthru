function renderReportsPeriod(tab, period) {
  if (tab === 'bid') {
    renderBidKPIs(period);
    renderBidCharts(period);
    renderBidTable(period);
  } else if (tab === 'production' && rptPeriodData.production[period]) {
    var kpis = rptPeriodData.production[period].kpis;
    renderTabKPIs(kpis, '#rpt-production', 'production');
    renderProductionCharts(period);
    renderProductionTable(period);
  } else if (tab === 'quality' && rptPeriodData.quality[period]) {
    var kpis = rptPeriodData.quality[period].kpis;
    renderTabKPIs(kpis, '#rpt-quality', 'quality');
    renderQualityCharts(period);
    renderQualityTable(period);
  } else if (tab === 'utilization' && rptPeriodData.utilization[period]) {
    var kpis = rptPeriodData.utilization[period].kpis;
    renderTabKPIs(kpis, '#rpt-utilization', 'utilization');
    renderUtilizationCharts(period);
    renderUtilizationTable(period);
  }
}

function renderTabKPIs(kpis, tabSelector, tabName) {
  var tab = document.querySelector(tabSelector);
  if (!tab) return;
  var cards = tab.querySelectorAll('.rpt-kpi');
  for (var i = 0; i < kpis.length && i < cards.length; i++) {
    var k = kpis[i];
    var label = cards[i].querySelector('.stat-label');
    var val = cards[i].querySelector('.stat-value');
    var sub = cards[i].querySelector('.stat-sub');

    if (label) label.innerHTML = k.label + '<span class="mi">north_east</span>';
    var dynColor = getKpiColor(tabName, i, k.value) || k.color;
    if (val) {
      val.textContent = k.value;
      val.style.color = dynColor;
    }
    if (sub) {
      sub.textContent = k.sub;
      sub.className = 'stat-sub';
    }
    if (k.bars) {
      var sparkContainer = cards[i].querySelector('[style*="display:flex"][style*="gap:2px"][style*="height:28px"]');
      if (sparkContainer) sparkContainer.innerHTML = buildSparkHTML(k.bars, dynColor);
    }
  }
}

function selectRptPeriod(el) {
  el.parentNode.querySelectorAll('.mm-period-tab').forEach(t => t.classList.remove('active'));
  el.classList.add('active');

  var period = el.textContent.trim();
  var tabContent = null;
  document.querySelectorAll('.rpt-tab-content').forEach(function(tc) {
    if (tc.style.display === 'block') tabContent = tc;
  });
  if (!tabContent) tabContent = document.getElementById('rpt-bid');
  if (!tabContent) return;

  var currentTab = tabContent.id.replace('rpt-', '');
  renderReportsPeriod(currentTab, period);
}

