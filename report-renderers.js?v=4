// ===== REPORT RENDERERS =====
// Report rendering functions and metrics overlay

function buildSparkHTML(bars, color) {
  var maxH = 28;
  var maxVal = Math.max.apply(null, bars);
  var html = '';
  bars.forEach(function(v, idx) {
    var h = Math.round((v / maxVal) * maxH);
    var op = bars.length === 1 ? 1 : (0.4 + (0.6 * idx / (bars.length - 1)));
    if (idx === bars.length - 1) op = 1;
    html += '<div style="width:4px;border-radius:1px;background:' + color + ';opacity:' + op.toFixed(1) + ';height:' + h + 'px"></div>';
  });
  return html;
}

function renderBidKPIs(period) {
  var data = rptPeriodData.bid[period];
  if (!data) return;
  var kpis = data.kpis;
  var tab = document.getElementById('rpt-bid');
  if (!tab) return;
  var cards = tab.querySelectorAll('.rpt-kpi');
  for (var i = 0; i < kpis.length && i < cards.length; i++) {
    var k = kpis[i];
    var label = cards[i].querySelector('.stat-label');
    var val = cards[i].querySelector('.stat-value');
    var sub = cards[i].querySelector('.stat-sub');
    if (label) label.innerHTML = k.label + '<span class="mi">north_east</span>';
    var dynColor = getKpiColor('bid', i, k.value) || k.color;
    if (val) { val.textContent = k.value; val.style.color = dynColor; }
    if (sub) {
      sub.textContent = k.sub;
      sub.className = 'stat-sub';
      if (k.sub.includes('+')) sub.classList.add('success');
    }
    if (k.bars) {
      var sparkContainer = cards[i].querySelector('[style*="display:flex"][style*="gap:2px"][style*="height:28px"]');
      if (sparkContainer) sparkContainer.innerHTML = buildSparkHTML(k.bars, dynColor);
    }
  }
}

function renderBidCharts(period) {
  var data = rptPeriodData.bid[period];
  if (!data) return;

  // Hit Rate by Shipyard
  var hitrateDiv = document.getElementById('rpt-chart-hitrate-shipyard');
  if (hitrateDiv) {
    var html = '';
    data.hitrateShipyard.forEach(function(item) {
      html += '<div style="display:flex;align-items:center;gap:12px">' +
        '<div style="width:130px;font-size:12px;color:var(--steel-300);text-align:right;flex-shrink:0">' + item.name + '</div>' +
        '<div style="flex:1;height:20px;background:var(--steel-700);border-radius:3px;position:relative;overflow:hidden">' +
        '<div style="width:' + item.pct + '%;height:100%;background:' + item.color + ';border-radius:3px;display:flex;align-items:center;justify-content:flex-end;padding-right:6px;font-size:10px;font-weight:700;color:var(--steel-900)">' + item.pct + '%</div>' +
        '</div><div style="width:40px;font-size:11px;color:var(--steel-400);text-align:right">' + item.ratio + '</div></div>';
    });
    hitrateDiv.innerHTML = html;
  }

  // Margin by Program
  var marginDiv = document.getElementById('rpt-chart-margin-program');
  if (marginDiv) {
    var html = '';
    data.marginProgram.forEach(function(item) {
      var barColor = item.pct >= 22 ? 'var(--success)' : item.pct >= 17 ? 'var(--warning)' : 'var(--danger)';
      html += '<div style="display:flex;align-items:center;gap:12px">' +
        '<div style="width:80px;font-size:12px;color:var(--steel-300);text-align:right;flex-shrink:0">' + item.name + '</div>' +
        '<div style="flex:1;height:20px;background:var(--steel-700);border-radius:3px;position:relative;overflow:hidden">' +
        '<div style="width:' + item.barPct + '%;height:100%;background:' + barColor + ';border-radius:3px;display:flex;align-items:center;justify-content:flex-end;padding-right:6px;font-size:10px;font-weight:700;color:var(--steel-900)">' + item.pct.toFixed(1) + '%</div>' +
        '</div></div>';
    });
    marginDiv.innerHTML = html;
  }

  // Quote Cycle Time Trend (floor=2, range=5, target=3.5 → 30%)
  var cycleDiv = document.getElementById('rpt-chart-cycle-trend');
  if (cycleDiv && data.cycleTrend) {
    var floor = 2, range = 5, barH = 130;
    var targetPx = Math.round(((3.5 - floor) / range) * barH);
    // Value labels row
    var html = '<div style="display:flex;gap:0;margin-bottom:2px">';
    data.cycleTrend.forEach(function(item) {
      html += '<div style="flex:1;text-align:center;font-size:9px;color:var(--steel-400);font-weight:600">' + item.val + '</div>';
    });
    html += '</div>';
    // Bar area with target line
    html += '<div style="position:relative;height:' + barH + 'px;display:flex;align-items:flex-end;gap:0">';
    html += '<div style="position:absolute;left:0;right:0;bottom:' + targetPx + 'px;height:0;border-top:1px dashed var(--steel-300);box-shadow:0 -0.5px 0 0 var(--steel-800),0 0.5px 0 0 var(--steel-800);z-index:1"></div>';
    data.cycleTrend.forEach(function(item) {
      var barColor = item.val > 4.5 ? 'var(--danger)' : item.val > 3.5 ? (item.val > 4.0 ? 'var(--warning)' : 'var(--yellow)') : 'var(--success)';
      var barPx = Math.round(((item.val - floor) / range) * barH);
      html += '<div style="flex:1;display:flex;justify-content:center"><div style="width:60%;height:' + barPx + 'px;background:' + barColor + ';border-radius:3px 3px 0 0;min-width:12px"></div></div>';
    });
    html += '</div>';
    // Month labels row
    html += '<div style="display:flex;gap:0;margin-top:2px">';
    data.cycleTrend.forEach(function(item) {
      html += '<div style="flex:1;text-align:center;font-size:9px;color:var(--steel-400)">' + item.label + '</div>';
    });
    html += '</div>';
    cycleDiv.innerHTML = html;
  }

  // Hit Rate by Customer
  var custDiv = document.getElementById('rpt-chart-hitrate-customer');
  if (custDiv && data.hitrateCustomer) {
    var html = '';
    data.hitrateCustomer.forEach(function(item) {
      html += '<div style="display:flex;align-items:center;gap:12px">' +
        '<div style="width:130px;font-size:12px;color:var(--steel-300);text-align:right;flex-shrink:0">' + item.name + '</div>' +
        '<div style="flex:1;height:18px;background:var(--steel-700);border-radius:3px;overflow:hidden">' +
        '<div style="width:' + item.pct + '%;height:100%;background:' + item.color + ';border-radius:3px;display:flex;align-items:center;justify-content:flex-end;padding-right:6px;font-size:10px;font-weight:700;color:var(--steel-900)">' + item.pct + '%</div>' +
        '</div></div>';
    });
    custDiv.innerHTML = html;
  }
}

