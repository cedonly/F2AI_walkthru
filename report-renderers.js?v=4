function renderQualityCharts(period) {
  var data = rptPeriodData.quality[period];
  if (!data) return;

  // NCR by Root Cause
  var rootCauseDiv = document.getElementById('rpt-qual-rootcause');
  if (rootCauseDiv && data.rootCause) {
    var html = '';
    data.rootCause.forEach(function(item) {
      html += '<div style="display:flex;align-items:center;gap:12px"><div style="width:100px;font-size:12px;color:var(--steel-300);text-align:right;flex-shrink:0">' + item.name + '</div><div style="flex:1;height:20px;background:var(--steel-700);border-radius:3px;overflow:hidden"><div style="width:' + item.barPct + '%;height:100%;background:' + item.color + ';border-radius:3px;display:flex;align-items:center;padding-left:6px;font-size:10px;font-weight:700;color:#fff">' + item.count + '</div></div></div>';
    });
    rootCauseDiv.innerHTML = html;
  }

  // NCR Trend (uses max-value scaling, no floor needed — values vary enough)
  var ncrTrendDiv = document.getElementById('rpt-qual-ncrtrend');
  if (ncrTrendDiv && data.ncrTrend) {
    var maxVal = Math.max.apply(null, data.ncrTrend.map(function(x) { return x.val; }));
    // Value labels row
    var html = '<div style="display:flex;gap:0;margin-bottom:2px">';
    data.ncrTrend.forEach(function(item) {
      html += '<div style="flex:1;text-align:center;font-size:9px;color:var(--steel-400);font-weight:600">' + item.val + '</div>';
    });
    html += '</div>';
    // Bar area
    var barH = 130;
    html += '<div style="position:relative;height:' + barH + 'px;display:flex;align-items:flex-end;gap:0">';
    data.ncrTrend.forEach(function(item) {
      var barPx = maxVal > 0 ? Math.round((item.val / maxVal) * barH) : 0;
      html += '<div style="flex:1;display:flex;justify-content:center"><div style="width:60%;height:' + barPx + 'px;background:' + item.color + ';border-radius:3px 3px 0 0;min-width:12px"></div></div>';
    });
    html += '</div>';
    // Month labels row
    html += '<div style="display:flex;gap:0;margin-top:2px">';
    data.ncrTrend.forEach(function(item) {
      html += '<div style="flex:1;text-align:center;font-size:9px;color:var(--steel-400)">' + item.label + '</div>';
    });
    html += '</div>';
    ncrTrendDiv.innerHTML = html;
  }

  // NCR by Work Center
  var ncrWCDiv = document.getElementById('rpt-qual-ncrbywc');
  if (ncrWCDiv && data.ncrByWC) {
    var html = '';
    data.ncrByWC.forEach(function(item) {
      html += '<div style="display:flex;align-items:center;gap:12px"><div style="width:90px;font-size:12px;color:var(--steel-300);text-align:right;flex-shrink:0">' + item.name + '</div><div style="flex:1;height:18px;background:var(--steel-700);border-radius:3px;overflow:hidden"><div style="width:' + item.barPct + '%;height:100%;background:' + item.color + ';border-radius:3px;display:flex;align-items:center;padding-left:6px;font-size:10px;font-weight:700;color:#fff">' + item.count + '</div></div></div>';
    });
    ncrWCDiv.innerHTML = html;
  }

  // FPY by Work Center
  var fpyDiv = document.getElementById('rpt-qual-fpybywc');
  if (fpyDiv && data.fpyByWC) {
    var html = '';
    data.fpyByWC.forEach(function(item) {
      html += '<div><div style="display:flex;justify-content:space-between;margin-bottom:4px"><span style="font-size:12px;color:var(--steel-300)">' + item.name + '</span><span style="font-size:12px;font-weight:600;color:' + item.color + '">' + item.pct + '%</span></div><div style="height:6px;background:var(--steel-700);border-radius:3px;overflow:hidden"><div style="width:' + item.pct + '%;height:100%;background:' + item.color + ';border-radius:3px"></div></div></div>';
    });
    fpyDiv.innerHTML = html;
  }
}

