function getRptOverlayTheme(key) {
  var d = rptOverlayData[key];
  var colorFn = rptOverlayBarColor[key];
  if (!d || !colorFn) return d && d.theme ? d.theme : '';
  var numVal = parseFloat(d.value.replace(/[^0-9.\-]/g, ''));
  if (isNaN(numVal)) return d.theme || '';
  var barClass = colorFn(numVal);
  var map = {'bar-success':'success','bar-yellow':'yellow','bar-warn':'warn','bar-danger':'danger'};
  return map[barClass] || '';
}

function openRptOverlay(key) {
  var d = rptOverlayData[key];
  if (!d) return;
  _currentRptOverlayKey = key;
  var modal = document.getElementById('rpt-modal');
  var computedTheme = getRptOverlayTheme(key);
  var theme = computedTheme ? ' mm-theme-' + computedTheme : '';
  modal.className = 'metric-modal' + theme;
  var thHtml = d.headers.map(function(h){return '<th>'+h+'</th>'}).join('');
  var rowsHtml = d.breakdown.map(function(r){return '<tr>'+r.map(function(c){return colorCodeCell(c)}).join('')+'</tr>'}).join('');
  var aiInsightHtml = d.aiInsight ? '<div class="mm-ai-insight" id="rpt-ai-insight"><div class="mm-ai-icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L14.4 9.6L22 12L14.4 14.4L12 22L9.6 14.4L2 12L9.6 9.6Z"/></svg></div><div class="mm-ai-text">' + d.aiInsight + '</div><button class="mm-ai-dismiss" onclick="document.getElementById(\'rpt-ai-insight\').remove()" title="Dismiss"><span class="mi" style="font-size:16px">close</span></button></div>' : '';
  var aiOpen = document.getElementById('ai-panel').classList.contains('open');
  var aiBtnActive = aiOpen ? ' active' : '';

  // Detect period tabs based on overlay key prefix
  var periodTabsHtml = '';
  var defaultPeriod = '12M';
  var periods = [];

  if (key.startsWith('bid-')) {
    periods = ['3M', '6M', '12M', 'YTD'];
    defaultPeriod = '12M';
  } else if (key.startsWith('prod-')) {
    periods = ['Today', 'This Week', 'This Month', 'Quarter'];
    defaultPeriod = 'Today';
  } else if (key.startsWith('qual-')) {
    periods = ['This Month', 'Quarter', '12 Months', 'All Time'];
    defaultPeriod = 'Quarter';
  } else if (key.startsWith('util-')) {
    periods = ['Today', 'This Week', 'This Month', 'YTD'];
    defaultPeriod = 'Today';
  }

  if (periods.length > 0) {
    periodTabsHtml = '<div class="mm-period-tabs">';
    periods.forEach(function(p) {
      var activeClass = p === defaultPeriod ? ' active' : '';
      periodTabsHtml += '<button class="mm-period-tab' + activeClass + '" onclick="selectRptOverlayPeriod(this,\'' + p + '\')">' + p + '</button>';
    });
    periodTabsHtml += '</div>';
  }

  modal.innerHTML = '<div class="mm-header"><div class="mm-title">'+d.title+'</div><div style="display:flex;align-items:center;gap:4px"><button class="mm-ai-btn' + aiBtnActive + '" onclick="event.stopPropagation();toggleAI()" title="Ask AI about this metric"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L14.4 9.6L22 12L14.4 14.4L12 22L9.6 14.4L2 12L9.6 9.6Z"/></svg></button><button class="mm-close" id="rpt-overlay-close" onclick="closeRptOverlay()"><span class="mi" style="font-size:20px">close</span></button></div></div>'
    +'<div class="mm-body"><div class="mm-body-top">'
    + aiInsightHtml
    +'<div class="mm-value-row"><div class="mm-current"><span class="mm-big-value">'+d.value+'</span><span class="mm-change '+d.changeDir+'">'+d.change+'</span>'+(d.subtitle ? '<div class="mm-subtitle">'+d.subtitle+'</div>' : '')+'</div>' + periodTabsHtml + '</div>'
    +'<div class="mm-chart" id="rpt-chart-area"></div>'
    +'</div>'
    +'<div class="mm-breakdown"><h4>Breakdown</h4><div class="mm-breakdown-scroll"><table><thead><tr>'+thHtml+'</tr></thead><tbody>'+rowsHtml+'</tbody></table></div></div></div>';

  if (periods.length > 0) {
    renderRptOverlayChart(defaultPeriod);
    // Update big value for default period
    if (d.periodValues && d.periodValues[defaultPeriod]) {
      var pv = d.periodValues[defaultPeriod];
      var bigEl = modal.querySelector('.mm-big-value');
      var changeEl = modal.querySelector('.mm-change');
      if (bigEl) bigEl.textContent = pv.value;
      if (changeEl) {
        changeEl.textContent = pv.change;
        changeEl.className = 'mm-change ' + (pv.changeDir || '');
      }
    }
  }

  document.getElementById('rpt-overlay').classList.add('open');
}

function closeRptOverlay() {
  document.getElementById('rpt-overlay').classList.remove('open');
}

// Derive overlay theme from the current value using bar color thresholds
function getMetricTheme(key) {
  const d = metricData[key];
  const colorFn = metricBarColor[key];
  if (!d || !colorFn) return '';
  // Parse numeric value from the display string
  const numVal = parseFloat(d.value.replace(/[^0-9.\-]/g, ''));
  if (isNaN(numVal)) return '';
  const barClass = colorFn(numVal);
  const map = {'bar-success':'success','bar-yellow':'yellow','bar-warn':'warn','bar-danger':'danger'};
  return map[barClass] || '';
}

function openMetric(key) {
  const d = metricData[key];
  if (!d) return;
  _currentMetricKey = key;
  const modal = document.getElementById('metric-modal');
  const theme = getMetricTheme(key);
  modal.className = 'metric-modal' + (theme ? ' mm-theme-' + theme : '');
  const rowsHtml = d.breakdown.map(r => '<tr>' + r.map(c => '<td>' + c + '</td>').join('') + '</tr>').join('');
  const thHtml = d.breakdownHeaders.map(h => '<th>' + h + '</th>').join('');
  const aiInsightHtml = d.aiInsight ? '<div class="mm-ai-insight" id="mm-ai-insight"><div class="mm-ai-icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L14.4 9.6L22 12L14.4 14.4L12 22L9.6 14.4L2 12L9.6 9.6Z"/></svg></div><div class="mm-ai-text">' + d.aiInsight + '</div><button class="mm-ai-dismiss" onclick="document.getElementById(\'mm-ai-insight\').remove()" title="Dismiss"><span class="mi" style="font-size:16px">close</span></button></div>' : '';
  const aiBtnActive = aiOpen ? ' active' : '';
  modal.innerHTML = '<div class="mm-header"><div class="mm-title">' + d.title + '</div><div style="display:flex;align-items:center;gap:4px"><button class="mm-ai-btn' + aiBtnActive + '" onclick="event.stopPropagation();toggleAI()" title="Ask AI about this metric"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L14.4 9.6L22 12L14.4 14.4L12 22L9.6 14.4L2 12L9.6 9.6Z"/></svg></button><button class="mm-close" onclick="closeMetric()"><span class="mi" style="font-size:20px">close</span></button></div></div>'
    + '<div class="mm-body">'
    + '<div class="mm-body-top">'
    + aiInsightHtml
    + '<div class="mm-value-row"><div class="mm-current"><span class="mm-big-value">' + d.value + '</span><span class="mm-change ' + d.changeDir + '">' + d.change + '</span></div>'
    + '<div class="mm-period-tabs"><button class="mm-period-tab" onclick="selectPeriod(this,\'3M\')">3M</button><button class="mm-period-tab active" onclick="selectPeriod(this,\'6M\')">6M</button><button class="mm-period-tab" onclick="selectPeriod(this,\'12M\')">12M</button><button class="mm-period-tab" onclick="selectPeriod(this,\'YTD\')">YTD</button></div></div>'
    + '<div class="mm-chart" id="mm-chart-area"></div>'
    + '</div>'
    + '<div class="mm-breakdown"><h4>Breakdown</h4><div class="mm-breakdown-scroll"><table><thead><tr>' + thHtml + '</tr></thead><tbody>' + rowsHtml + '</tbody></table></div></div>'
    + '</div>';
  renderMetricChart('6M');
  document.getElementById('metric-overlay').classList.add('open');
}

function closeMetric() {
  document.getElementById('metric-overlay').classList.remove('open');
  _currentMetricKey = null;
}
document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape' && document.getElementById('metric-overlay').classList.contains('open')) closeMetric();
});

