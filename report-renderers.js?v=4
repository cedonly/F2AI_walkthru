function renderUtilizationCharts(period) {
  var data = rptPeriodData.utilization[period];
  if (!data) return;

  // Hours by Work Center
  var hoursWCDiv = document.getElementById('rpt-util-hourswc');
  if (hoursWCDiv && data.hoursWC) {
    var html = '';
    data.hoursWC.forEach(function(item) {
      html += '<div><div style="display:flex;justify-content:space-between;margin-bottom:4px"><span style="font-size:12px;color:var(--steel-300)">' + item.name + '</span><span style="font-size:12px;color:var(--steel-200)">' + item.logged + ' / ' + item.available + ' hrs</span></div><div style="height:12px;background:var(--steel-700);border-radius:4px;overflow:hidden"><div style="width:' + item.pct + '%;height:100%;background:' + item.color + ';border-radius:4px"></div></div></div>';
    });
    hoursWCDiv.innerHTML = html;
  }

  // Utilization Trend (floor=50, range=50, target=80 → 60%)
  var trendDiv = document.getElementById('rpt-util-trend');
  if (trendDiv && data.utilTrend) {
    var floor = 50, range = 50, barH = 130;
    var targetPx = Math.round(((80 - floor) / range) * barH);
    // Value labels row
    var html = '<div style="display:flex;gap:0;margin-bottom:2px">';
    data.utilTrend.forEach(function(item) {
      html += '<div style="flex:1;text-align:center;font-size:9px;color:var(--steel-400);font-weight:600">' + item.pct + '%</div>';
    });
    html += '</div>';
    // Bar area with target line
    html += '<div style="position:relative;height:' + barH + 'px;display:flex;align-items:flex-end;gap:0">';
    html += '<div style="position:absolute;left:0;right:0;bottom:' + targetPx + 'px;height:0;border-top:1px dashed var(--steel-300);box-shadow:0 -0.5px 0 0 var(--steel-800),0 0.5px 0 0 var(--steel-800);z-index:1"></div>';
    data.utilTrend.forEach(function(item) {
      var barPx = Math.round(((item.pct - floor) / range) * barH);
      html += '<div style="flex:1;display:flex;justify-content:center"><div style="width:60%;height:' + barPx + 'px;background:' + item.color + ';border-radius:3px 3px 0 0;min-width:12px"></div></div>';
    });
    html += '</div>';
    // Week labels row
    html += '<div style="display:flex;gap:0;margin-top:2px">';
    data.utilTrend.forEach(function(item) {
      html += '<div style="flex:1;text-align:center;font-size:9px;color:var(--steel-400)">' + item.label + '</div>';
    });
    html += '</div>';
    trendDiv.innerHTML = html;
  }

  // Hours by Job
  var hoursJobDiv = document.getElementById('rpt-util-hoursjob');
  if (hoursJobDiv && data.hoursJob) {
    var html = '';
    data.hoursJob.forEach(function(item) {
      html += '<div style="display:flex;align-items:center;gap:12px"><div style="width:110px;font-size:12px;color:var(--steel-300);text-align:right;flex-shrink:0">' + item.id + '</div><div style="flex:1;height:18px;background:var(--steel-700);border-radius:3px;overflow:hidden"><div style="width:' + item.barPct + '%;height:100%;background:' + item.color + ';border-radius:3px;display:flex;align-items:center;justify-content:flex-end;padding-right:6px;font-size:10px;font-weight:700;color:var(--steel-900)">' + item.hours + ' hrs</div></div></div>';
    });
    hoursJobDiv.innerHTML = html;
  }

  // Idle Time Breakdown
  var idleDiv = document.getElementById('rpt-util-idle');
  if (idleDiv && data.idle) {
    var html = '<div style="display:flex;height:24px;border-radius:4px;overflow:hidden;margin-bottom:8px">';
    data.idle.forEach(function(item) {
      html += '<div style="width:' + item.pct + '%;background:' + item.color + ';display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;color:var(--steel-900)" title="' + item.name + '">' + item.pct + '%</div>';
    });
    html += '</div><div style="display:flex;gap:12px;flex-wrap:wrap">';
    data.idle.forEach(function(item) {
      html += '<div style="display:flex;align-items:center;gap:6px;font-size:11px;color:var(--steel-300)"><div style="width:8px;height:8px;border-radius:2px;background:' + item.color + '"></div>' + item.name + '</div>';
    });
    html += '</div>';
    idleDiv.innerHTML = html;
  }

  // Update period labels
  if (data.periodLabels) {
    var labels = data.periodLabels;
    var el;
    if (labels.hoursWC && (el = document.getElementById('rpt-util-hourswc-period'))) el.textContent = labels.hoursWC;
    if (labels.hoursJob && (el = document.getElementById('rpt-util-hoursjob-period'))) el.textContent = labels.hoursJob;
    if (labels.idle && (el = document.getElementById('rpt-util-idle-period'))) el.textContent = labels.idle;
    if (labels.table && (el = document.getElementById('rpt-util-table-period'))) el.textContent = labels.table;
  }
}

