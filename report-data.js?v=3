function switchAdminTab(tab) {
  const tabMap = { shop:'admin-shop', users:'admin-users', compliance:'admin-compliance', integrations:'admin-integrations' };
  document.querySelectorAll('.admin-tab-content').forEach(c => c.style.display = 'none');
  const target = document.getElementById(tabMap[tab]);
  if (target) target.style.display = 'block';
  const bar = document.getElementById('admin-tab-bar');
  if (bar) {
    const btns = bar.querySelectorAll('.seg-btn');
    btns.forEach(t => t.classList.remove('active'));
    const idx = { shop:0, compliance:1, integrations:2, users:3 }[tab];
    if (btns[idx]) btns[idx].classList.add('active');
  }
  // Update info note
  var noteEl = document.getElementById('admin-info-note');
  var textEl = document.getElementById('admin-info-text');
  if (noteEl && textEl) {
    var iconEl = noteEl.querySelector('.mi');
    var notes = {
      shop: { icon:'info', color:'var(--cyan-400)', text:'Visible to <strong>Bid/PM</strong> (view rates &amp; materials), <strong>Planner</strong> (full edit), <strong>Quality/Eng</strong> (view; edit routing templates). Not visible to Operators.' },
      compliance: { icon:'info', color:'var(--cyan-400)', text:'Editable by <strong>Quality/Eng</strong> and <strong>Admin</strong>. Viewable by <strong>Bid/PM</strong> and <strong>Planner</strong>. Not visible to Operators.' },
      integrations: { icon:'lock', color:'var(--orange)', text:'<strong>Admin only.</strong> This section is restricted to system administrators. Other roles do not see this tab.' },
      users: { icon:'lock', color:'var(--orange)', text:'<strong>Admin only.</strong> This section is restricted to system administrators. Other roles do not see this tab.' }
    };
    var n = notes[tab];
    if (n) {
      noteEl.style.color = n.color;
      iconEl.textContent = n.icon;
      textEl.innerHTML = n.text;
    }
  }
}

