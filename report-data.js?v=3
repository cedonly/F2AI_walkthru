// Map report tab KPI indices to overlay bar color keys for dynamic coloring
var rptKpiColorKeys = {
  bid: ['bid-hitrate', 'bid-cycle', 'bid-margin', 'bid-pipeline'],
  production: ['prod-activejobs', 'prod-ontime', 'prod-overdue', 'prod-duration'],
  quality: ['qual-openncrs', 'qual-firstpass', 'qual-escaperate', 'qual-costncr'],
  utilization: ['util-machinetime', 'kpi-util-hours', 'kpi-util-operators', 'kpi-util-idle']
};

function getKpiColor(tabName, kpiIndex, value) {
  var keys = rptKpiColorKeys[tabName];
  if (!keys || !keys[kpiIndex]) return null;
  var colorFn = rptOverlayBarColor[keys[kpiIndex]];
  if (!colorFn) return null;
  var numVal = parseFloat(String(value).replace(/[^0-9.\-]/g, ''));
  if (isNaN(numVal)) return null;
  var barClass = colorFn(numVal);
  var colorMap = {'bar-success':'var(--success)', 'bar-yellow':'var(--yellow)', 'bar-warn':'var(--warning)', 'bar-danger':'var(--danger)'};
  return colorMap[barClass] || null;
}

function renderMetricChart(period) {
  const d = metricData[_currentMetricKey];
  if (!d) return;
  const p = d.periods[period];
  if (!p) return;
  const chart = document.getElementById('mm-chart-area');
  if (!chart) return;
  const maxH = 120;
  const colorFn = metricBarColor[_currentMetricKey];
  chart.innerHTML = p.d.map(m => {
    const h = Math.round((m.v / p.max) * maxH);
    const barClass = colorFn ? colorFn(m.v) : 'bar-yellow';
    return '<div class="mm-chart-bar-group"><div class="mm-chart-val">' + m.v + '</div><div class="mm-chart-bar ' + barClass + '" style="height:' + h + 'px"></div><div class="mm-chart-label">' + m.l + '</div></div>';
  }).join('');
}

function selectPeriod(el, period) {
  el.parentNode.querySelectorAll('.mm-period-tab').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
  renderMetricChart(period);
}

var _currentRptOverlayKey = null;

function colorCodeCell(text) {
  var t = text.toLowerCase();
  // Status keywords
  if (t === 'on track' || t === 'won' || t === 'active' || t === 'pass' || t === 'complete' || t === 'shipped' || t === 'materials ok' || t === 'on floor')
    return '<td style="color:var(--success);font-weight:600">' + text + '</td>';
  if (t === 'at risk' || t === 'pending' || t === 'available' || t === 'scheduled' || t === 'queue' || t === 'backlog')
    return '<td style="color:var(--yellow);font-weight:600">' + text + '</td>';
  if (t === 'behind' || t === 'major' || t.includes('down '))
    return '<td style="color:var(--warning);font-weight:600">' + text + '</td>';
  if (t === 'critical' || t === 'lost' || t === 'overdue')
    return '<td style="color:var(--danger);font-weight:600">' + text + '</td>';
  if (t === 'minor')
    return '<td style="color:var(--yellow);font-weight:600">' + text + '</td>';
  // Trend arrows — context-aware: ↓ in time/cost = good, ↓ in rate/% = bad
  var isLowerBetter = /[d$k]/.test(t) && !/\d+%/.test(t);
  if (text.startsWith('↑')) {
    if (isLowerBetter) return '<td style="color:var(--danger)">' + text + '</td>';
    return '<td style="color:var(--success)">' + text + '</td>';
  }
  if (text.startsWith('↓')) {
    if (isLowerBetter) return '<td style="color:var(--success)">' + text + '</td>';
    return '<td style="color:var(--danger)">' + text + '</td>';
  }
  // Delay values like "2d late", "5d late"
  if (/\d+d\s*late/.test(t))
    return '<td style="color:var(--danger)">' + text + '</td>';
  // Overdue counts
  if (/\d+\s*overdue/.test(t))
    return '<td style="color:var(--danger)">' + text + '</td>';
  if (/0\s*overdue/.test(t))
    return '<td style="color:var(--success)">' + text + '</td>';
  return '<td>' + text + '</td>';
}

function renderRptOverlayChart(period) {
  var d = rptOverlayData[_currentRptOverlayKey];
  if (!d || !d.periods) return;
  var p = d.periods[period];
  if (!p) return;
  var chart = document.getElementById('rpt-chart-area');
  if (!chart) return;
  var maxH = 120;
  var colorFn = rptOverlayBarColor[_currentRptOverlayKey];
  chart.innerHTML = p.d.map(function(m) {
    var h = Math.round((m.v / p.max) * maxH);
    var barClass = colorFn ? colorFn(m.v) : 'bar-yellow';
    return '<div class="mm-chart-bar-group"><div class="mm-chart-val">' + m.v + '</div><div class="mm-chart-bar ' + barClass + '" style="height:' + h + 'px"></div><div class="mm-chart-label">' + m.l + '</div></div>';
  }).join('');
}

function selectRptOverlayPeriod(el, period) {
  el.parentNode.querySelectorAll('.mm-period-tab').forEach(function(t) { t.classList.remove('active'); });
  el.classList.add('active');
  renderRptOverlayChart(period);

  // Update big value from period-specific data
  var d = rptOverlayData[_currentRptOverlayKey];
  if (d && d.periodValues && d.periodValues[period]) {
    var pv = d.periodValues[period];
    var bigEl = document.querySelector('#rpt-modal .mm-big-value');
    var changeEl = document.querySelector('#rpt-modal .mm-change');
    if (bigEl) bigEl.textContent = pv.value;
    if (changeEl) {
      changeEl.textContent = pv.change;
      changeEl.className = 'mm-change ' + (pv.changeDir || '');
    }
    // Update theme color
    var colorFn = rptOverlayBarColor[_currentRptOverlayKey];
    if (colorFn) {
      var numVal = parseFloat(String(pv.value).replace(/[^0-9.\-]/g, ''));
      if (!isNaN(numVal)) {
        var barClass = colorFn(numVal);
        var themeMap = {'bar-success':'success','bar-yellow':'yellow','bar-warn':'warn','bar-danger':'danger'};
        var newTheme = themeMap[barClass] || '';
        var modal = document.getElementById('rpt-modal');
        modal.className = 'metric-modal' + (newTheme ? ' mm-theme-' + newTheme : '');
      }
    }
  }
}

