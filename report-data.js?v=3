function switchReportsTab(tab) {
  const tabMap = { bid:'rpt-bid', production:'rpt-production', quality:'rpt-quality', utilization:'rpt-utilization' };
  document.querySelectorAll('.rpt-tab-content').forEach(c => c.style.display = 'none');
  const target = document.getElementById(tabMap[tab]);
  if (target) target.style.display = 'block';
  const chips = document.getElementById('reports-chips');
  if (chips) {
    chips.querySelectorAll('.seg-btn').forEach(c => c.classList.remove('active'));
    const idx = { bid:0, production:1, quality:2, utilization:3 }[tab];
    if (chips.children[idx]) chips.children[idx].classList.add('active');
  }
  // Update period popover per tab
  var periods = { bid: ['3M','6M','12M','YTD'], production: ['Today','This Week','This Month','Quarter'], quality: ['This Month','Quarter','12 Months','All Time'], utilization: ['Today','This Week','This Month','YTD'] };
  var defaults = { bid: '12M', production: 'Today', quality: 'Quarter', utilization: 'Today' };
  var def = defaults[tab];
  var optsHtml = (periods[tab] || []).map(function(p) {
    return '<div class="sort-opt' + (p === def ? ' active' : '') + '" data-period="' + p + '" onclick="pickRptPeriod(this)">' + p + '</div>';
  }).join('');
  var triggerHtml = '<div class="sort-wrap" id="rpt-period-wrap"><button class="sort-trigger" onclick="toggleSortPop(\'rpt-period-pop\')"><span id="rpt-period-label">' + def + '</span><span class="sort-chevron"><svg xmlns="http://www.w3.org/2000/svg" width="10" height="6" fill="none"><path d="M1 1l4 4 4-4" stroke="#6b7280" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></span></button><div class="sort-pop" id="rpt-period-pop">' + optsHtml + '</div></div>';
  var ctrl = document.querySelector('.rpt-controls');
  if (ctrl) ctrl.innerHTML = triggerHtml + '<button class="btn btn-secondary btn-md"><span class="mi" style="font-size:18px">download</span> Export</button>';

  // Render with default period
  renderReportsPeriod(tab, def);
}
function pickRptPeriod(el) {
  var period = el.getAttribute('data-period');
  var pop = document.getElementById('rpt-period-pop');
  if (pop) {
    pop.querySelectorAll('.sort-opt').forEach(function(o) { o.classList.remove('active'); });
    el.classList.add('active');
  }
  var label = document.getElementById('rpt-period-label');
  if (label) label.textContent = period;
  var wrap = document.getElementById('rpt-period-wrap');
  if (wrap) wrap.classList.remove('open');
  if (pop) pop.classList.remove('open');
  var tab = document.querySelector('#reports-chips .seg-btn.active');
  var tabMap = { 'Bid Performance':'bid', 'Production':'production', 'Quality':'quality', 'Utilization':'utilization' };
  var currentTab = tab ? tabMap[tab.textContent] : 'bid';
  renderReportsPeriod(currentTab, period);
}
